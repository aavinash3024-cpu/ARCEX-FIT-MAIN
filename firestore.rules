rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PulseFlow Security Rules
     *
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model where all personal health data is
     * private to the authenticated user. It utilizes Structural Segregation to separate 
     * public system resources (like global food and exercise databases) from private user data.
     *
     * Data Structure:
     * Most data is hierarchically nested under /userProfiles/{userId}/ to leverage path-based
     * authorization. Global references are stored in root collections /foodItems and /exercises.
     *
     * Key Security Decisions:
     * - Authorization Independence: Critical IDs (userId, creatorId) are denormalized onto 
     *   documents to allow for fast, local authorization checks without cross-document reads.
     * - Public Read/Private Write: System-wide libraries are readable by anyone but 
     *   restricted from client-side writes to maintain data integrity.
     * - Relational Integrity: On creation and update, rules verify that internal document 
     *   fields match the URL path parameters to prevent data being written into the wrong scope.
     */

    // --- Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the user is the owner and the document exists (for updates/deletes). */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** Validates that the internal ID field matches the path parameter. */
    function idMatchesPath(idField, pathId) {
      return idField == pathId;
    }

    /** Validates that a field remains unchanged during an update. */
    function isImmutable(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the root user profile. Users can only manage their own profile.
     * @path /userProfiles/{userId}
     * @allow (get, update) if UID matches userId.
     * @deny (create) if UID does not match userId.
     * @principle Ownership and Relational Integrity.
     */
    match /userProfiles/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && idMatchesPath(request.resource.data.id, userId);
      allow update: if isExistingOwner(userId) && isImmutable('id');
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Subcollection for user-specific metrics, goals, tasks, and workout splits.
     * @path /userProfiles/{userId}/[subcollection]/{id}
     * @allow (all) if the authenticated user is the path owner.
     * @deny (all) if the user attempts to access another user's subcollection.
     * @principle Scoped access based on parent user ID.
     */
    match /userProfiles/{userId}/dailyMetrics/{metricId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && idMatchesPath(request.resource.data.userId, userId);
      allow update: if isExistingOwner(userId) && isImmutable('userId');
      allow delete: if isExistingOwner(userId);
    }

    match /userProfiles/{userId}/goals/{goalId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && idMatchesPath(request.resource.data.userId, userId);
      allow update: if isExistingOwner(userId) && isImmutable('userId');
      allow delete: if isExistingOwner(userId);
    }

    match /userProfiles/{userId}/tasks/{taskId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && idMatchesPath(request.resource.data.userId, userId);
      allow update: if isExistingOwner(userId) && isImmutable('userId');
      allow delete: if isExistingOwner(userId);
    }

    match /userProfiles/{userId}/personalRecords/{prId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && idMatchesPath(request.resource.data.userId, userId);
      allow update: if isExistingOwner(userId) && isImmutable('userId');
      allow delete: if isExistingOwner(userId);
    }

    match /userProfiles/{userId}/workoutSplits/{splitId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && idMatchesPath(request.resource.data.userId, userId);
      allow update: if isExistingOwner(userId) && isImmutable('userId');
      allow delete: if isExistingOwner(userId);

      match /splitDays/{dayId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && idMatchesPath(request.resource.data.workoutSplitId, splitId);
        allow update: if isExistingOwner(userId) && isImmutable('workoutSplitId');
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Deeply nested nutritional and workout data.
     * @path /userProfiles/{userId}/dailyMetrics/{metricId}/[meals|workouts]
     * @allow (all) if authenticated user matches the root userId.
     * @principle Multi-level path ownership.
     */
    match /userProfiles/{userId}/dailyMetrics/{metricId}/meals/{mealId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && idMatchesPath(request.resource.data.dailyMetricId, metricId);
      allow update: if isExistingOwner(userId) && isImmutable('dailyMetricId');
      allow delete: if isExistingOwner(userId);

      match /mealEntries/{entryId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && idMatchesPath(request.resource.data.mealId, mealId);
        allow update: if isExistingOwner(userId) && isImmutable('mealId');
        allow delete: if isExistingOwner(userId);
      }
    }

    match /userProfiles/{userId}/dailyMetrics/{metricId}/workouts/{workoutId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && idMatchesPath(request.resource.data.dailyMetricId, metricId);
      allow update: if isExistingOwner(userId) && isImmutable('dailyMetricId');
      allow delete: if isExistingOwner(userId);

      match /workoutExercises/{exerciseId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && idMatchesPath(request.resource.data.workoutId, workoutId);
        allow update: if isExistingOwner(userId) && isImmutable('workoutId');
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description User-created custom food items and exercises.
     * @path /userProfiles/{userId}/userFoodItems/{id}
     * @allow (all) if the creatorId matches the authenticated user.
     * @principle Ownership of custom library items.
     */
    match /userProfiles/{userId}/userFoodItems/{foodId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && idMatchesPath(request.resource.data.creatorId, userId);
      allow update: if isExistingOwner(userId) && isImmutable('creatorId');
      allow delete: if isExistingOwner(userId);
    }

    match /userProfiles/{userId}/userExercises/{exerciseId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && idMatchesPath(request.resource.data.creatorId, userId);
      allow update: if isExistingOwner(userId) && isImmutable('creatorId');
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Global system libraries for food and exercises.
     * @path /foodItems/{id}
     * @allow (read) for all users.
     * @deny (write) for all users (Admin only via Backend).
     * @principle Public consumption with restricted creation.
     */
    match /foodItems/{foodId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Admin authorization logic
    }

    match /exercises/{exerciseId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Admin authorization logic
    }
  }
}